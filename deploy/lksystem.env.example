# Copy this file to deploy/lksystem.env and change every secret before deploy.
DOMAIN=lksystem.therapybylk.com

# Django
SECRET_KEY=change-this-to-a-long-random-secret
DEBUG=False
DJANGO_LOG_LEVEL=INFO

# Database
POSTGRES_DB=lksystem
POSTGRES_USER=lksystem_user
POSTGRES_PASSWORD=change-this-database-password

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Bootstrap admin. Leave false after first setup.
AUTO_CREATE_DEFAULT_ADMIN=false
DEFAULT_ADMIN_MATRICULE=SUPERADMIN-0001
DEFAULT_ADMIN_EMAIL=admin@lksystem.therapybylk.com
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
DEFAULT_ADMIN_FIRST_NAME=Super
DEFAULT_ADMIN_LAST_NAME=Admin

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=LkSystem <noreply@lksystem.therapybylk.com>

# Delivery provider
DELIVERY_API_URL=https://core.jax-delivery.com/api/user/colis/add
DELIVERY_API_TOKEN=
DELIVERY_API_TIMEOUT=15
